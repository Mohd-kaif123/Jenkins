'''
pipeline {
    agent any
    stages{
        stage('Build') {
            steps {
                echo "building the application"
                sh 'npm install'
            }
        }
        stage('test') {
            echo "Running test"
            sh 'npm test'
        }
    }
}
---

pipeline {
    agent any
    stages{
        stage('hello') {
            steps {
                echo "Hello Jenkins"
            }
        }
    }
}

---

pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                echo "checkout stage running"
            }
        }
        stage('Build') {
            steps {
                echo "Build ho raha hai"
            }
        }
        stage('Test') {
            steps {
                echo "Test ho raha hai"
            }
        }
    }
}
'''
'''
pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                echo "Checkout is running"
            }
        }
        stage('Build') {
            steps {
                echo "Build ho raha hai"
                sh 'ls -la'
            }
        }
        stage('Test') {
            steps {
                echo "Test ho raha hai"
                sh 'exit 1'
            }
        } 
    }
}
'''

'''
pipeline {
    agent any
    environment {
        APP_ENV = 'staging'
    }
    stages {
        stage ('Build') {
            steps {
                echo "$APP_ENV"
            }
        }
    }
}
'''
'''
pipeline {
    agent any
    environment {
    // environment hamesa agent any ke baad aur stages se pahale lkhte hai.
    // Environment variable ko hamesa '$' sign ke saath use karo jab print/use karna ho, 
    // '=' sign sirf define karte waqt use hota hai
        APP_ENV = 'staging'
    }
    stages {
        stage('Build') {
            steps {
                echo "build ho raha hai"
                echo "Current Environment is: ${APP_ENV}"
            }
        }
    }
    post {
        always {
           echo "Pipeline execution completed" 
        }
        success {
            echo "Build passed!"
        }
        failure {
            echo "Build failed, check logs"
        }
    }
}

pipeline {
    agent any
    stages {
        stage('build') {
            steps {
                echo "Build ho raha hai"
            }
        }
        stage('deploy') {
        // ye if condition hai, Is stage ko tabhi chalao jab branch main ho, warna skip kardo
            when {
                branch 'main'
            }
            steps {
                echo "Deploying to production"
            }
        }
    }
}

pipeline {
    agent any
    options {
        timeout(time: 10, unit: 'MINUTES')
    }
    // kabhi kabhi build scripts kisi error, network issue, 
    // ya input prompt ki wajah se infinite loop me fass sakta hai.
    // agar timeout set nahi hoga, toh aapka jenkins agent ghanto tak busy rahega aur aapke resources(and cost) waste hote rahenge.
    stages {
        stage('build') {
            steps {
                echo "build ho raha hai"
            }
        }
        stage('deploy') {
            steps {
                echo "build complete hogaeya"
            }
        }
    }
}

pipeline {
    agent any
    
    parameters {
        // Name ko 'RUN_TESTS' kiya taaki niche use kiya ja sake
        booleanParam(name: 'RUN_TESTS', defaultValue: true, description: 'Do you want to run tests?')  
    }
    
    stages {
        stage('Test') {
            when {
                expression {
                    // Spelling thik ki: params.RUN_TESTS
                    params.RUN_TESTS == true
                }
            }
            steps {
                echo "This parameter check is done, running tests!"
            }
        }
    }
}
'''