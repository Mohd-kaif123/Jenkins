'''
pipeline {
    agent any
    stages{
        stage('Build') {
            steps {
                echo "building the application"
                sh 'npm install'
            }
        }
        stage('test') {
            echo "Running test"
            sh 'npm test'
        }
    }
}
---

pipeline {
    agent any
    stages{
        stage('hello') {
            steps {
                echo "Hello Jenkins"
            }
        }
    }
}

---

pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                echo "checkout stage running"
            }
        }
        stage('Build') {
            steps {
                echo "Build ho raha hai"
            }
        }
        stage('Test') {
            steps {
                echo "Test ho raha hai"
            }
        }
    }
}
'''
'''
pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                echo "Checkout is running"
            }
        }
        stage('Build') {
            steps {
                echo "Build ho raha hai"
                sh 'ls -la'
            }
        }
        stage('Test') {
            steps {
                echo "Test ho raha hai"
                sh 'exit 1'
            }
        } 
    }
}
'''

'''
pipeline {
    agent any
    environment {
        APP_ENV = 'staging'
    }
    stages {
        stage ('Build') {
            steps {
                echo "$APP_ENV"
            }
        }
    }
}
'''
'''
pipeline {
    agent any
    environment {
        APP_ENV = 'staging'
    }
    stages {
        stage('Build') {
            steps {
                echo "build ho raha hai"
                echo "Current Environment is: ${APP_ENV}"
            }
        }
    }
    post {
        always {
           echo "Pipeline execution completed" 
        }
        success {
            echo "Build passed!"
        }
        failure {
            echo "Build failed, check logs"
        }
    }
}

pipeline {
    agent any
    stages {
        stage('build') {
            steps {
                echo "Build ho raha hai"
            }
        }
        stage('deploy') {
            when {
                branch 'main'
            }
            steps {
                echo "Deploying to production"
            }
        }
    }
}
'''
